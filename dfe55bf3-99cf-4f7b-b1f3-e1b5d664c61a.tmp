      <div class="proj-title">App Mobile Fintech</div>
      <div class="proj-desc">Aplicativo para gestão financeira com dashboard interativo e notificações inteligentes.</div>
      <div class="proj-tags">
        <span class="proj-tag">Flutter</span>
        <span class="proj-tag">Spring</span>
        <span class="proj-tag">MongoDB</span>
      </div>
    </div>
    <div class="proj-card">
      <div class="proj-num">03</div>
      <div class="proj-title">Painel de Monitoramento</div>
      <div class="proj-desc">Dashboard real-time para infraestrutura, logs e métricas de performance de servidores.</div>
      <div class="proj-tags">
        <span class="proj-tag">Vue.js</span>
        <span class="proj-tag">Node.js</span>
        <span class="proj-tag">Linux</span>
        <span class="proj-tag">Nginx</span>
      </div>
    </div>
  </div>
</div>

<!-- ===== CONTACT ===== -->
<div class="panel p-center p-contact" id="panel-contact">
  <button class="close-btn" onclick="go('hero')">×</button>
  <div class="tag">contato</div>
  <div class="title">Vamos<br><span class="gradient">construir?</span></div>
  <div class="subtitle">Tem um projeto em mente? Vamos dar vida a ele.</div>
  <div class="contact-items">
    <a href="mailto:gabriel@email.com" class="cta-link">
      <div class="cta-icon">@</div>
      <div><div class="cta-label">E-mail</div><div class="cta-text">gabriel@email.com</div></div>
    </a>
    <a href="https://github.com/gabrielinacio" target="_blank" class="cta-link">
      <div class="cta-icon">&lt;/&gt;</div>
      <div><div class="cta-label">GitHub</div><div class="cta-text">github.com/gabrielinacio</div></div>
    </a>
    <a href="https://linkedin.com/in/gabrielinacio" target="_blank" class="cta-link">
      <div class="cta-icon">in</div>
      <div><div class="cta-label">LinkedIn</div><div class="cta-text">linkedin.com/in/gabrielinacio</div></div>
    </a>
  </div>
  <button class="contact-cta-button" onclick="window.open('mailto:gabriel@email.com')">ENVIAR MENSAGEM →</button>
</div>

<!-- Bottom bar -->
<div class="bottom-bar">
  <div class="nav-hint">⌁ ARRASTE PARA EXPLORAR</div>
  <div class="cam-coords" id="camCoords">0.0 · 0.0 · 0.0</div>
</div>

<!-- ====== THREE.JS ====== -->
<script type="importmap">
{
  "imports": {
    "three": "https://cdn.jsdelivr.net/npm/three@0.160.0/build/three.module.js",
    "three/addons/": "https://cdn.jsdelivr.net/npm/three@0.160.0/examples/jsm/"
  }
}
</script>
<script type="module">
import * as THREE from 'three';
import { GLTFLoader } from 'three/addons/loaders/GLTFLoader.js';
import { OrbitControls } from 'three/addons/controls/OrbitControls.js';

/* ============ SCENE ============ */
const container = document.getElementById('scene-container');
const scene = new THREE.Scene();
scene.background = new THREE.Color(0x04040c);
scene.fog = new THREE.FogExp2(0x04040c, 0.007);

const camera = new THREE.PerspectiveCamera(45, innerWidth / innerHeight, 0.1, 800);
camera.position.set(45, 28, 45);

const renderer = new THREE.WebGLRenderer({ antialias: true, powerPreference: 'high-performance' });
renderer.setPixelRatio(Math.min(devicePixelRatio, 2));
renderer.setSize(innerWidth, innerHeight);
renderer.toneMapping = THREE.ACESFilmicToneMapping;
renderer.toneMappingExposure = 0.7;
renderer.shadowMap.enabled = true;
renderer.shadowMap.type = THREE.PCFSoftShadowMap;
container.appendChild(renderer.domElement);

/* ============ CONTROLS ============ */
const controls = new OrbitControls(camera, renderer.domElement);
controls.enableDamping = true;
controls.dampingFactor = 0.04;
controls.rotateSpeed = 0.4;
controls.zoomSpeed = 0.7;
controls.panSpeed = 0.4;
controls.minDistance = 8;
controls.maxDistance = 130;
controls.maxPolarAngle = Math.PI / 2.05;
controls.target.set(0, 2, 0);

/* ============ LIGHTING ============ */
scene.add(new THREE.AmbientLight(0x151530, 0.8));

const moon = new THREE.DirectionalLight(0x3355aa, 1.4);
moon.position.set(35, 55, 25);
moon.castShadow = true;
moon.shadow.mapSize.set(2048, 2048);
const s = 65;
moon.shadow.camera.left = -s; moon.shadow.camera.right = s;
moon.shadow.camera.top = s; moon.shadow.camera.bottom = -s;
moon.shadow.camera.near = 0.5; moon.shadow.camera.far = 160;
scene.add(moon);

// Neon lights array for animation
const neons = [
  (() => { const l = new THREE.PointLight(0x00e5ff, 4, 55); l.position.set(15, 7, 12); scene.add(l); return l; })(),
  (() => { const l = new THREE.PointLight(0xf637ec, 3, 45); l.position.set(-14, 5, -10); scene.add(l); return l; })(),
  (() => { const l = new THREE.PointLight(0xff6b35, 2, 35); l.position.set(8, 4, -18); scene.add(l); return l; })(),
  (() => { const l = new THREE.PointLight(0x39ff14, 1.5, 25); l.position.set(-20, 6, 15); scene.add(l); return l; })(),
];

scene.add(new THREE.DirectionalLight(0x00e5ff, 0.2).position.set(-35, 12, -35) && new THREE.DirectionalLight(0x00e5ff, 0.2));

/* ============ GROUND ============ */
const ground = new THREE.Mesh(
  new THREE.PlaneGeometry(400, 400),
  new THREE.MeshStandardMaterial({ color: 0x060610, roughness: 0.95, metalness: 0.05 })
);
ground.rotation.x = -Math.PI / 2;
ground.position.y = -0.5;
ground.receiveShadow = true;
scene.add(ground);

/* Grid */
const grid = new THREE.GridHelper(250, 100, 0x00e5ff, 0x0a0a22);
grid.position.y = -0.45;
grid.material.opacity = 0.1;
grid.material.transparent = true;
scene.add(grid);

/* ============ PARTICLES ============ */
const pCount = 500;
const pGeo = new THREE.BufferGeometry();
const pPos = new Float32Array(pCount * 3);
const pSpeeds = new Float32Array(pCount);
for (let i = 0; i < pCount; i++) {
  pPos[i*3] = (Math.random()-0.5) * 180;
  pPos[i*3+1] = Math.random() * 70 + 3;
  pPos[i*3+2] = (Math.random()-0.5) * 180;
  pSpeeds[i] = 0.02 + Math.random() * 0.04;
}
pGeo.setAttribute('position', new THREE.BufferAttribute(pPos, 3));
const pMat = new THREE.PointsMaterial({ color: 0x00e5ff, size: 0.12, transparent: true, opacity: 0.5, sizeAttenuation: true });
scene.add(new THREE.Points(pGeo, pMat));

/* ============ LOAD MODEL ============ */
const loader = new GLTFLoader();
const loaderFill = document.getElementById('loaderFill');
const loaderStatus = document.getElementById('loaderStatus');
const loaderEl = document.getElementById('loader');

async function loadModel() {
  try {
    loaderStatus.textContent = 'carregando cidade 3d...';
    const response = await fetch('city.glb');
    if (!response.ok) throw new Error(`HTTP ${response.status}`);

    const total = parseInt(response.headers.get('content-length') || '0', 10);
    const reader = response.body.getReader();
    const chunks = [];
    let loaded = 0;

    while (true) {
      const { done, value } = await reader.read();
      if (done) break;
      chunks.push(value);
      loaded += value.length;
      if (total > 0) {
        const pct = Math.round((loaded / total) * 100);
        loaderFill.style.width = pct + '%';
        loaderStatus.textContent = `carregando cidade... ${pct}%`;
      }
    }

    loaderStatus.textContent = 'renderizando...';
    const buffer = await new Blob(chunks).arrayBuffer();

    loader.parse(buffer, '', (gltf) => {
      const model = gltf.scene;
      const box = new THREE.Box3().setFromObject(model);
      const center = box.getCenter(new THREE.Vector3());
      const size = box.getSize(new THREE.Vector3());
      const scale = 45 / Math.max(size.x, size.y, size.z);
      model.scale.setScalar(scale);
      model.position.sub(center.multiplyScalar(scale));
      model.position.y = 0;

      model.traverse(c => {
        if (c.isMesh) {
          c.castShadow = true;
          c.receiveShadow = true;
          if (c.material) c.material.envMapIntensity = 0.4;
        }
      });

      scene.add(model);

      const nb = new THREE.Box3().setFromObject(model);
      const nc = nb.getCenter(new THREE.Vector3());
      controls.target.copy(nc);
      controls.target.y = nc.y + 1.5;

      loaderFill.style.width = '100%';
      loaderStatus.textContent = 'pronto!';
      setTimeout(() => {
        loaderEl.classList.add('done');
        setTimeout(() => showPanel('hero'), 600);
      }, 500);
    }, err => {
      console.error('Parse error:', err);
      loaderStatus.textContent = 'erro ao processar modelo';
    });
  } catch (err) {
    console.error('Fetch error:', err);
    loaderStatus.textContent = 'erro ao carregar: ' + err.message;
  }
}
loadModel();

/* ============ CAMERA PRESETS ============ */
const presets = {
  hero:     { pos: [45, 28, 45],   target: [0, 2, 0] },
  about:    { pos: [-35, 38, 28],  target: [0, 5, 0] },
  stack:    { pos: [8, 50, -8],    target: [0, 0, 0] },
  projects: { pos: [-18, 14, 38],  target: [5, 3, 5] },
  contact:  { pos: [28, 10, -32],  target: [0, 4, 0] },
};

let current = 'hero';
let animating = false;

function lerpCam(toPos, toTarget, dur = 2200) {
  if (animating) return;
  animating = true;
  const from = camera.position.clone();
  const fromT = controls.target.clone();
  const to = new THREE.Vector3(...toPos);
  const toT = new THREE.Vector3(...toTarget);
  const t0 = performance.now();

  function tick(now) {
    const p = Math.min((now - t0) / dur, 1);
    const e = p < 0.5 ? 4*p*p*p : 1 - Math.pow(-2*p+2, 3) / 2;
    camera.position.lerpVectors(from, to, e);
    controls.target.lerpVectors(fromT, toT, e);
    controls.update();
    if (p < 1) requestAnimationFrame(tick);
    else animating = false;
  }
  requestAnimationFrame(tick);
}

/* ============ PANEL MANAGEMENT ============ */
const panels = document.querySelectorAll('.panel');
const pills = document.querySelectorAll('.pill');
const dots = document.querySelectorAll('.sec-dot');

function hideAll() { panels.forEach(p => p.classList.remove('show')); }

function showPanel(sec) {
  hideAll();
  const el = document.getElementById(`panel-${sec}`);
  if (el) setTimeout(() => el.classList.add('show'), 80);
  pills.forEach(p => p.classList.toggle('active', p.dataset.sec === sec));
  dots.forEach(d => d.classList.toggle('active', d.dataset.section === sec));
}

window.go = function(sec) {
  if (sec === current && sec !== 'hero') return;
  current = sec;
  const p = presets[sec];
  if (p) lerpCam(p.pos, p.target);
  showPanel(sec);
  closeMobileMenu();
};

/* Nav pills */
pills.forEach(p => p.addEventListener('click', () => go(p.dataset.sec)));
dots.forEach(d => d.addEventListener('click', () => go(d.dataset.section)));

/* Hamburger */
const burger = document.getElementById('burger');
const navPills = document.getElementById('navPills');
function closeMobileMenu() { navPills.classList.remove('open'); burger.classList.remove('open'); }
burger.addEventListener('click', () => { navPills.classList.toggle('open'); burger.classList.toggle('open'); });

/* ============ CURSOR ============ */
const dot = document.getElementById('cursorDot');
const ring = document.getElementById('cursorRing');
let mx = 0, my = 0, rx = 0, ry = 0;

document.addEventListener('mousemove', e => {
  mx = e.clientX; my = e.clientY;
  dot.style.left = mx + 'px'; dot.style.top = my + 'px';
});
function cursorLoop() {
  rx += (mx - rx) * 0.12;
  ry += (my - ry) * 0.12;
  ring.style.left = rx + 'px'; ring.style.top = ry + 'px';
  requestAnimationFrame(cursorLoop);
}
cursorLoop();

document.querySelectorAll('a,button,.pill,.chip,.proj-card,.cta-link,.highlight-card,.sec-dot,.close-btn,.contact-cta-button').forEach(el => {
  el.addEventListener('mouseenter', () => ring.classList.add('hovering'));
  el.addEventListener('mouseleave', () => ring.classList.remove('hovering'));
});

/* ============ RESIZE ============ */
addEventListener('resize', () => {
  camera.aspect = innerWidth / innerHeight;
  camera.updateProjectionMatrix();
  renderer.setSize(innerWidth, innerHeight);
});

/* ============ KEYBOARD NAV ============ */
const sections = ['hero','about','stack','projects','contact'];
addEventListener('keydown', e => {
  const idx = sections.indexOf(current);
  if ((e.key === 'ArrowDown' || e.key === 'ArrowRight') && idx < sections.length - 1) go(sections[idx+1]);
  if ((e.key === 'ArrowUp' || e.key === 'ArrowLeft') && idx > 0) go(sections[idx-1]);
});

/* ============ RENDER LOOP ============ */
const clock = new THREE.Clock();
const coordsEl = document.getElementById('camCoords');

function animate() {
  requestAnimationFrame(animate);
  const t = clock.getElapsedTime();

  // Animate neon lights
  neons[0].position.y = 7 + Math.sin(t * 0.5) * 2.5;
  neons[0].intensity = 4 + Math.sin(t * 1.3) * 1;
  neons[1].position.y = 5 + Math.sin(t * 0.65 + 1) * 2;
  neons[1].intensity = 3 + Math.sin(t * 1.1 + 0.5) * 0.8;
  neons[2].position.y = 4 + Math.sin(t * 0.4 + 2) * 1.5;
  neons[3].position.y = 6 + Math.sin(t * 0.55 + 3) * 1.8;

  // Drift particles
  const pos = pGeo.attributes.position.array;
  for (let i = 0; i < pCount; i++) {
    pos[i*3+1] += pSpeeds[i] * 0.3;
    if (pos[i*3+1] > 75) pos[i*3+1] = 3;
  }
  pGeo.attributes.position.needsUpdate = true;

  // Grid pulse
  grid.material.opacity = 0.08 + Math.sin(t * 0.4) * 0.03;

  // Coords
  coordsEl.textContent = `${camera.position.x.toFixed(1)} · ${camera.position.y.toFixed(1)} · ${camera.position.z.toFixed(1)}`;

  controls.update();
  renderer.render(scene, camera);
}
animate();
</script>
</body>
</html>
