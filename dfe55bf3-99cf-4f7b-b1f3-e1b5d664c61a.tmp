<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Gabriel Inácio — Dev FullStack</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@200;300;400;500;600;700;800;900&family=JetBrains+Mono:wght@300;400;500;700&family=Syne:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

:root {
  --cyan: #00e5ff;
  --cyan-dim: rgba(0,229,255,0.15);
  --magenta: #f637ec;
  --magenta-dim: rgba(246,55,236,0.12);
  --orange: #ff6b35;
  --green: #39ff14;
  --dark: #06060e;
  --dark-2: #0c0c18;
  --panel-bg: rgba(8, 8, 18, 0.92);
  --panel-border: rgba(0,229,255,0.18);
  --glass: rgba(255,255,255,0.03);
  --text-1: #eeeef4;
  --text-2: #7878a0;
  --text-3: #4a4a6a;
  --font-display: 'Syne', sans-serif;
  --font-mono: 'JetBrains Mono', monospace;
  --font-body: 'Outfit', sans-serif;
  --radius: 8px;
}

html, body {
  width: 100%; height: 100%;
  overflow: hidden;
  background: var(--dark);
  color: var(--text-1);
  font-family: var(--font-body);
}

/* ============ CUSTOM CURSOR ============ */
.cursor-dot {
  position: fixed; width: 6px; height: 6px;
  background: var(--cyan);
  border-radius: 50%;
  pointer-events: none; z-index: 99999;
  transform: translate(-50%, -50%);
  mix-blend-mode: screen;
  box-shadow: 0 0 12px var(--cyan), 0 0 25px rgba(0,229,255,0.25);
  transition: width 0.2s, height 0.2s, background 0.3s;
}
.cursor-ring {
  position: fixed; width: 32px; height: 32px;
  border: 1px solid rgba(0,229,255,0.4);
  border-radius: 50%;
  pointer-events: none; z-index: 99998;
  transform: translate(-50%, -50%);
  transition: width 0.35s cubic-bezier(.22,1,.36,1), height 0.35s cubic-bezier(.22,1,.36,1), border-color 0.3s, background 0.3s;
}
.cursor-ring.hovering {
  width: 52px; height: 52px;
  border-color: var(--magenta);
  background: rgba(246,55,236,0.06);
}
@media (pointer: coarse) {
  .cursor-dot, .cursor-ring { display: none !important; }
  html, body { cursor: auto; }
}
@media (pointer: fine) {
  html, body { cursor: none; }
}

/* ============ LOADER ============ */
#loader {
  position: fixed; inset: 0; z-index: 10000;
  background: var(--dark);
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  transition: opacity 1s ease, visibility 1s;
}
#loader.done { opacity: 0; visibility: hidden; pointer-events: none; }

.loader-logo {
  font-family: var(--font-display);
  font-size: clamp(1.5rem, 5vw, 2.4rem);
  font-weight: 800;
  letter-spacing: 0.08em;
  margin-bottom: 3rem;
  position: relative;
}
.loader-logo .g { color: var(--cyan); }
.loader-logo .dot { color: var(--magenta); }
.loader-logo .rest { color: var(--text-1); }

.loader-track {
  width: min(80vw, 320px); height: 2px;
  background: rgba(255,255,255,0.06);
  border-radius: 2px;
  overflow: hidden;
}
.loader-fill {
  height: 100%; width: 0%;
  background: linear-gradient(90deg, var(--cyan), var(--magenta));
  border-radius: 2px;
  transition: width 0.2s;
}
.loader-status {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  color: var(--text-3);
  margin-top: 1.2rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
}
.loader-tip {
  font-family: var(--font-mono);
  font-size: 0.55rem;
  color: var(--text-3);
  margin-top: 2.5rem;
  opacity: 0.4;
}

/* ============ CANVAS ============ */
#scene-container { position: fixed; inset: 0; z-index: 1; }

/* ============ GRAIN OVERLAY ============ */
.grain {
  position: fixed; inset: 0; z-index: 80;
  pointer-events: none;
  opacity: 0.035;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  background-size: 128px 128px;
}

/* ============ VIGNETTE ============ */
.vignette {
  position: fixed; inset: 0; z-index: 79;
  pointer-events: none;
  background: radial-gradient(ellipse at 50% 50%, transparent 40%, rgba(6,6,14,0.65) 100%);
}

/* ============ TOP BAR / NAV ============ */
.topbar {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  display: flex; align-items: center; justify-content: space-between;
  padding: 1rem 1.8rem;
  background: linear-gradient(180deg, rgba(6,6,14,0.95) 0%, rgba(6,6,14,0.4) 70%, transparent 100%);
  pointer-events: none;
}
.topbar > * { pointer-events: all; }

.brand {
  font-family: var(--font-display);
  font-weight: 800;
  font-size: clamp(1rem, 2.5vw, 1.25rem);
  letter-spacing: 0.05em;
  user-select: none;
  display: flex; align-items: baseline; gap: 2px;
}
.brand .g { color: var(--cyan); }
.brand .dot { color: var(--magenta); font-size: 1.4em; line-height: 0; }
.brand .rest { color: var(--text-1); }

.nav-pills {
  display: flex; gap: 4px;
}
.pill {
  font-family: var(--font-mono);
  font-size: 0.62rem;
  font-weight: 500;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  padding: 0.45rem 0.9rem;
  background: transparent;
  border: 1px solid transparent;
  color: var(--text-2);
  border-radius: 100px;
  cursor: none;
  transition: all 0.3s;
  position: relative;
}
.pill:hover {
  color: var(--text-1);
  background: var(--glass);
  border-color: var(--panel-border);
}
.pill.active {
  color: var(--dark);
  background: var(--cyan);
  border-color: var(--cyan);
  box-shadow: 0 0 20px rgba(0,229,255,0.3);
}

/* Hamburger */
.hamburger {
  display: none; background: none; border: none;
  cursor: pointer; padding: 8px; z-index: 200;
  flex-direction: column; gap: 5px;
}
.hamburger span {
  display: block; width: 22px; height: 1.5px;
  background: var(--cyan);
  transition: all 0.35s cubic-bezier(.22,1,.36,1);
  transform-origin: center;
}
.hamburger.open span:nth-child(1) { transform: rotate(45deg) translate(4.5px, 4.5px); }
.hamburger.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
.hamburger.open span:nth-child(3) { transform: rotate(-45deg) translate(4.5px, -4.5px); }

@media (max-width: 640px) {
  .hamburger { display: flex; }
  .nav-pills {
    position: fixed; inset: 0;
    flex-direction: column;
    align-items: center; justify-content: center;
    gap: 0.6rem;
    background: rgba(6,6,14,0.98);
    backdrop-filter: blur(30px);
    opacity: 0; visibility: hidden;
    transition: all 0.4s;
  }
  .nav-pills.open { opacity: 1; visibility: visible; }
  .pill { font-size: 0.8rem; padding: 0.8rem 2rem; cursor: pointer; }
  .topbar { padding: 0.8rem 1rem; }
}

@media (pointer: coarse) {
  .pill { cursor: pointer; }
}

/* ============ PANELS ============ */
.panel {
  position: fixed; z-index: 50;
  background: var(--panel-bg);
  border: 1px solid var(--panel-border);
  border-radius: var(--radius);
  backdrop-filter: blur(25px) saturate(1.3);
  -webkit-backdrop-filter: blur(25px) saturate(1.3);
  opacity: 0; visibility: hidden;
  transform: translateY(40px) scale(0.97);
  transition: all 0.7s cubic-bezier(.22,1,.36,1);
  overflow-y: auto;
  max-height: 85vh;
  scrollbar-width: thin;
  scrollbar-color: rgba(0,229,255,0.2) transparent;
}
.panel::-webkit-scrollbar { width: 4px; }
.panel::-webkit-scrollbar-thumb { background: rgba(0,229,255,0.2); border-radius: 4px; }
.panel.show {
  opacity: 1; visibility: visible;
  transform: translateY(0) scale(1);
}

/* Panel glow stripe */
.panel::before {
  content: '';
  position: absolute; top: -1px; left: 20px; right: 20px;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--cyan) 30%, var(--magenta) 70%, transparent);
  border-radius: 1px;
}
/* Corner accents */
.panel::after {
  content: '';
  position: absolute; top: 8px; left: 8px;
  width: 16px; height: 16px;
  border-top: 1px solid var(--cyan);
  border-left: 1px solid var(--cyan);
  border-radius: 2px 0 0 0;
  opacity: 0.5;
}

/* Close */
.close-btn {
  position: absolute; top: 0.8rem; right: 0.8rem;
  width: 28px; height: 28px;
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 6px;
  color: var(--text-2);
  font-size: 0.9rem;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; transition: all 0.25s;
}
.close-btn:hover {
  background: rgba(246,55,236,0.1);
  border-color: var(--magenta);
  color: var(--magenta);
}
@media (pointer: coarse) { .close-btn { cursor: pointer; width: 36px; height: 36px; } }

/* ============ PANEL POSITIONS ============ */
.p-hero {
  bottom: 6%; left: 4%;
  width: min(92vw, 520px);
  padding: clamp(1.5rem, 4vw, 2.5rem);
}
.p-center {
  top: 50%; left: 50%;
  transform: translate(-50%, -50%) scale(0.97);
  padding: clamp(1.5rem, 4vw, 2.8rem);
}
.p-center.show { transform: translate(-50%, -50%) scale(1); }
.p-about { width: min(92vw, 640px); }
.p-stack { width: min(94vw, 780px); }
.p-projects { width: min(94vw, 820px); }
.p-contact { width: min(90vw, 480px); }

/* ============ TYPOGRAPHY ============ */
.tag {
  font-family: var(--font-mono);
  font-size: 0.6rem;
  text-transform: uppercase;
  letter-spacing: 0.3em;
  color: var(--cyan);
  margin-bottom: 0.6rem;
  display: flex; align-items: center; gap: 8px;
}
.tag::before {
  content: ''; width: 8px; height: 8px;
  background: var(--cyan);
  border-radius: 2px;
  box-shadow: 0 0 8px var(--cyan);
  animation: tag-pulse 2s infinite;
}
@keyframes tag-pulse {
  0%, 100% { opacity: 1; } 50% { opacity: 0.4; }
}

.title {
  font-family: var(--font-display);
  font-weight: 800;
  font-size: clamp(1.8rem, 5vw, 2.8rem);
  line-height: 1.05;
  letter-spacing: -0.01em;
  margin-bottom: 1rem;
}
.title .gradient {
  background: linear-gradient(135deg, var(--cyan) 0%, var(--magenta) 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  background-clip: text;
}

.subtitle {
  font-size: clamp(0.82rem, 1.8vw, 0.95rem);
  color: var(--text-2);
  line-height: 1.7;
  font-weight: 300;
}

/* ============ HERO ============ */
.hero-name {
  font-family: var(--font-display);
  font-weight: 800;
  font-size: clamp(2.8rem, 10vw, 5rem);
  line-height: 0.92;
  letter-spacing: -0.02em;
  margin-bottom: 0.5rem;
}
.hero-name .first { color: var(--text-1); }
.hero-name .last {
  display: block;
  background: linear-gradient(90deg, var(--cyan) 0%, var(--magenta) 80%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  background-clip: text;
}

.hero-role {
  font-family: var(--font-mono);
  font-size: clamp(0.62rem, 1.3vw, 0.75rem);
  letter-spacing: 0.18em;
  color: var(--cyan);
  text-transform: uppercase;
  margin-bottom: 1.8rem;
  overflow: hidden;
  white-space: nowrap;
  border-right: 2px solid var(--cyan);
  animation: typing 3s steps(35) 1.5s forwards, blink-caret 0.7s step-end infinite;
  width: 0;
  max-width: 100%;
}
@keyframes typing { to { width: 100%; } }
@keyframes blink-caret { 50% { border-color: transparent; } }

.hero-stats {
  display: flex; gap: 2rem; flex-wrap: wrap;
}
.stat-box {
  position: relative;
  padding-left: 1rem;
}
.stat-box::before {
  content: '';
  position: absolute; left: 0; top: 0; bottom: 0;
  width: 2px;
  background: linear-gradient(180deg, var(--cyan), transparent);
  border-radius: 1px;
}
.stat-val {
  font-family: var(--font-display);
  font-weight: 800;
  font-size: clamp(1.6rem, 4vw, 2.2rem);
  line-height: 1;
  color: var(--text-1);
}
.stat-label {
  font-family: var(--font-mono);
  font-size: 0.55rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--text-3);
  margin-top: 0.15rem;
}

/* ============ ABOUT ============ */
.about-body p {
  font-size: clamp(0.82rem, 1.6vw, 0.92rem);
  color: var(--text-2);
  line-height: 1.8;
  font-weight: 300;
  margin-bottom: 1rem;
}
.about-body strong {
  color: var(--cyan);
  font-weight: 500;
}

.about-highlights {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
  gap: 0.7rem;
  margin-top: 1.5rem;
}
.highlight-card {
  padding: 1rem;
  background: var(--glass);
  border: 1px solid rgba(255,255,255,0.05);
  border-radius: 6px;
  text-align: center;
  transition: all 0.3s;
}
.highlight-card:hover {
  border-color: var(--panel-border);
  background: var(--cyan-dim);
  transform: translateY(-2px);
}
.highlight-icon {
  font-size: 1.4rem;
  margin-bottom: 0.4rem;
}
.highlight-label {
  font-family: var(--font-mono);
  font-size: 0.6rem;
  color: var(--text-2);
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

/* ============ STACK ============ */
.stack-section-title {
  font-family: var(--font-mono);
  font-size: 0.62rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  margin-top: 1.5rem;
  margin-bottom: 0.7rem;
  display: flex; align-items: center; gap: 8px;
}
.stack-section-title .line { flex: 1; height: 1px; background: rgba(255,255,255,0.06); }
.stack-section-title.frontend { color: var(--cyan); }
.stack-section-title.mobile { color: var(--magenta); }
.stack-section-title.backend { color: var(--orange); }
.stack-section-title.database { color: var(--green); }
.stack-section-title.cloud { color: #a78bfa; }
.stack-section-title.security { color: #f87171; }

.stack-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
  gap: 0.5rem;
}
.chip {
  padding: 0.7rem 0.8rem;
  background: var(--glass);
  border: 1px solid rgba(255,255,255,0.05);
  border-radius: 6px;
  transition: all 0.3s;
  position: relative;
  overflow: hidden;
}
.chip::after {
  content: '';
  position: absolute; bottom: 0; left: 0;
  width: 0; height: 2px;
  transition: width 0.4s cubic-bezier(.22,1,.36,1);
}
.chip:hover { transform: translateY(-2px); }
.chip:hover::after { width: 100%; }

.frontend .chip:hover { border-color: var(--cyan); background: var(--cyan-dim); }
.frontend .chip::after { background: var(--cyan); }
.mobile .chip:hover { border-color: var(--magenta); background: var(--magenta-dim); }
.mobile .chip::after { background: var(--magenta); }
.backend .chip:hover { border-color: var(--orange); background: rgba(255,107,53,0.1); }
.backend .chip::after { background: var(--orange); }
.database .chip:hover { border-color: var(--green); background: rgba(57,255,20,0.08); }
.database .chip::after { background: var(--green); }
.cloud .chip:hover { border-color: #a78bfa; background: rgba(167,139,250,0.1); }
.cloud .chip::after { background: #a78bfa; }
.security .chip:hover { border-color: #f87171; background: rgba(248,113,113,0.1); }
.security .chip::after { background: #f87171; }

.chip-name {
  font-family: var(--font-body);
  font-size: 0.82rem;
  font-weight: 600;
  color: var(--text-1);
}
.chip-sub {
  font-family: var(--font-mono);
  font-size: 0.52rem;
  color: var(--text-3);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-top: 0.1rem;
}

/* ============ PROJECTS ============ */
.projects-list { display: flex; flex-direction: column; gap: 1rem; margin-top: 1.2rem; }

.proj-card {
  padding: 1.3rem 1.5rem;
  background: var(--glass);
  border: 1px solid rgba(255,255,255,0.05);
  border-radius: var(--radius);
  transition: all 0.4s;
  position: relative;
  overflow: hidden;
}
.proj-card::before {
  content: '';
  position: absolute; top: 0; left: 0; bottom: 0;
  width: 3px; border-radius: 3px 0 0 3px;
  transition: background 0.3s;
}
.proj-card:nth-child(1)::before { background: var(--cyan); }
.proj-card:nth-child(2)::before { background: var(--magenta); }
.proj-card:nth-child(3)::before { background: var(--orange); }

.proj-card:hover {
  border-color: var(--panel-border);
  background: rgba(255,255,255,0.04);
  transform: translateX(4px);
}
.proj-num {
  font-family: var(--font-display);
  font-size: 0.7rem;
  font-weight: 800;
  color: var(--text-3);
  letter-spacing: 0.2em;
  margin-bottom: 0.3rem;
}
.proj-title {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: clamp(1.1rem, 3vw, 1.4rem);
  color: var(--text-1);
  margin-bottom: 0.4rem;
}
.proj-desc {
  font-size: 0.82rem;
  color: var(--text-2);
  line-height: 1.6;
  font-weight: 300;
  margin-bottom: 0.7rem;
}
.proj-tags { display: flex; flex-wrap: wrap; gap: 0.35rem; }
.proj-tag {
  font-family: var(--font-mono);
  font-size: 0.55rem;
  letter-spacing: 0.08em;
  padding: 0.2rem 0.55rem;
  border: 1px solid rgba(0,229,255,0.15);
  border-radius: 100px;
  color: var(--cyan);
  background: var(--cyan-dim);
}

/* ============ CONTACT ============ */
.contact-items { display: flex; flex-direction: column; gap: 0.7rem; margin-top: 1.5rem; }
.cta-link {
  display: flex; align-items: center; gap: 1rem;
  padding: 0.9rem 1.2rem;
  background: var(--glass);
  border: 1px solid rgba(255,255,255,0.05);
  border-radius: var(--radius);
  text-decoration: none;
  color: var(--text-1);
  transition: all 0.3s;
}
.cta-link:hover {
  border-color: var(--cyan);
  background: var(--cyan-dim);
  transform: translateX(6px);
  box-shadow: 0 0 30px rgba(0,229,255,0.08);
}
.cta-icon {
  width: 36px; height: 36px;
  display: flex; align-items: center; justify-content: center;
  border: 1px solid var(--panel-border);
  border-radius: 6px;
  color: var(--cyan);
  font-family: var(--font-mono);
  font-size: 0.85rem;
  font-weight: 700;
  flex-shrink: 0;
}
.cta-text {
  font-family: var(--font-mono);
  font-size: 0.75rem;
  letter-spacing: 0.03em;
}
.cta-label {
  font-size: 0.55rem;
  color: var(--text-3);
  text-transform: uppercase;
  letter-spacing: 0.15em;
  margin-bottom: 0.1rem;
}

.contact-cta-button {
  margin-top: 1.5rem;
  width: 100%;
  padding: 0.9rem;
  font-family: var(--font-display);
  font-size: 1rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  color: var(--dark);
  background: linear-gradient(135deg, var(--cyan), var(--magenta));
  border: none;
  border-radius: var(--radius);
  cursor: pointer;
  transition: all 0.3s;
  box-shadow: 0 4px 25px rgba(0,229,255,0.3);
}
.contact-cta-button:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 35px rgba(0,229,255,0.45);
}

/* ============ BOTTOM BAR ============ */
.bottom-bar {
  position: fixed; bottom: 0; left: 0; right: 0; z-index: 100;
  padding: 0.8rem 1.8rem;
  display: flex; align-items: center; justify-content: space-between;
  background: linear-gradient(0deg, rgba(6,6,14,0.9) 0%, transparent 100%);
  pointer-events: none;
  font-family: var(--font-mono);
  font-size: 0.58rem;
  color: var(--text-3);
  letter-spacing: 0.12em;
}
.nav-hint { animation: pulse-hint 2.5s ease-in-out infinite; }
@keyframes pulse-hint { 0%,100% { opacity: 0.3; } 50% { opacity: 0.8; } }
.cam-coords { font-variant-numeric: tabular-nums; }

@media (max-width: 768px) {
  .bottom-bar { padding: 0.6rem 1rem; font-size: 0.5rem; }
}

/* ============ FLOATING INDICATORS ============ */
.section-indicator {
  position: fixed;
  left: 1.5rem; top: 50%;
  transform: translateY(-50%);
  z-index: 90;
  display: flex; flex-direction: column;
  gap: 12px;
}
.sec-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  background: rgba(255,255,255,0.12);
  transition: all 0.4s;
  cursor: pointer;
}
.sec-dot.active {
  background: var(--cyan);
  box-shadow: 0 0 10px var(--cyan);
  transform: scale(1.5);
}
@media (max-width: 768px) {
  .section-indicator { left: 0.6rem; gap: 8px; }
  .sec-dot { width: 4px; height: 4px; }
}
@media (pointer: coarse) { .sec-dot { cursor: pointer; } }

/* ============ PANEL APPEAR ANIMATION ============ */
@keyframes panel-in {
  from { opacity: 0; transform: translateY(30px) scale(0.96); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}
</style>
</head>
<body>

<!-- Cursor -->
<div class="cursor-dot" id="cursorDot"></div>
<div class="cursor-ring" id="cursorRing"></div>

<!-- Loader -->
<div id="loader">
  <div class="loader-logo">
    <span class="g">G</span><span class="dot">.</span><span class="rest">INÁCIO</span>
  </div>
  <div class="loader-track"><div class="loader-fill" id="loaderFill"></div></div>
  <div class="loader-status" id="loaderStatus">inicializando...</div>
  <div class="loader-tip">PORTFOLIO 3D · ARRASTE PARA EXPLORAR A CIDADE</div>
</div>

<!-- 3D -->
<div id="scene-container"></div>

<!-- Overlays -->
<div class="grain"></div>
<div class="vignette"></div>

<!-- Section dots -->
<div class="section-indicator" id="sectionDots">
  <div class="sec-dot active" data-section="hero"></div>
  <div class="sec-dot" data-section="about"></div>
  <div class="sec-dot" data-section="stack"></div>
  <div class="sec-dot" data-section="projects"></div>
  <div class="sec-dot" data-section="contact"></div>
</div>

<!-- Top bar -->
<nav class="topbar">
  <div class="brand">
    <span class="g">G</span><span class="dot">.</span><span class="rest">INÁCIO</span>
  </div>
  <button class="hamburger" id="burger" aria-label="Menu">
    <span></span><span></span><span></span>
  </button>
  <div class="nav-pills" id="navPills">
    <button class="pill active" data-sec="hero">Início</button>
    <button class="pill" data-sec="about">Sobre</button>
    <button class="pill" data-sec="stack">Stack</button>
    <button class="pill" data-sec="projects">Projetos</button>
    <button class="pill" data-sec="contact">Contato</button>
  </div>
</nav>

<!-- ===== HERO ===== -->
<div class="panel p-hero" id="panel-hero">
  <div class="tag">fullstack developer</div>
  <div class="hero-name">
    <span class="first">GABRIEL</span>
    <span class="last">INÁCIO</span>
  </div>
  <div class="hero-role" id="heroRole">&gt; dev fullstack · +3 anos de experiência _</div>
  <div class="hero-stats">
    <div class="stat-box">
      <div class="stat-val">3+</div>
      <div class="stat-label">anos de xp</div>
    </div>
    <div class="stat-box">
      <div class="stat-val">15+</div>
      <div class="stat-label">tecnologias</div>
    </div>
    <div class="stat-box">
      <div class="stat-val">∞</div>
      <div class="stat-label">curiosidade</div>
    </div>
  </div>
</div>

<!-- ===== ABOUT ===== -->
<div class="panel p-center p-about" id="panel-about">
  <button class="close-btn" onclick="go('hero')">×</button>
  <div class="tag">sobre mim</div>
  <div class="title">Quem habita<br><span class="gradient">essa cidade</span></div>
  <div class="about-body">
    <p>Desenvolvedor FullStack com mais de 3 anos transformando ideias em produtos reais. Do <strong>frontend pixel-perfect</strong> ao <strong>backend escalável</strong>, passando por infraestrutura cloud e segurança ofensiva.</p>
    <p>Minha abordagem: código limpo, arquitetura inteligente e obsessão por performance. Construo aplicações web e mobile, APIs robustas, pipelines de deploy e hardening de servidores.</p>
    <p>Cada prédio dessa cidade é uma skill. Cada rua, uma conexão entre tecnologias. <strong>Bem-vindo ao meu mundo.</strong></p>
  </div>
  <div class="about-highlights">
    <div class="highlight-card"><div class="highlight-icon">⚡</div><div class="highlight-label">Performance</div></div>
    <div class="highlight-card"><div class="highlight-icon">🛡️</div><div class="highlight-label">Segurança</div></div>
    <div class="highlight-card"><div class="highlight-icon">📱</div><div class="highlight-label">Mobile</div></div>
    <div class="highlight-card"><div class="highlight-icon">☁️</div><div class="highlight-label">Cloud</div></div>
  </div>
</div>

<!-- ===== STACK ===== -->
<div class="panel p-center p-stack" id="panel-stack">
  <button class="close-btn" onclick="go('hero')">×</button>
  <div class="tag">tecnologias</div>
  <div class="title">Meu <span class="gradient">arsenal</span></div>

  <div class="frontend">
    <div class="stack-section-title frontend">Frontend <span class="line"></span></div>
    <div class="stack-grid">
      <div class="chip"><div class="chip-name">React</div><div class="chip-sub">UI Library</div></div>
      <div class="chip"><div class="chip-name">Vue.js</div><div class="chip-sub">Framework</div></div>
      <div class="chip"><div class="chip-name">Next.js</div><div class="chip-sub">React Meta</div></div>
      <div class="chip"><div class="chip-name">Nuxt</div><div class="chip-sub">Vue Meta</div></div>
    </div>
  </div>
  <div class="mobile">
    <div class="stack-section-title mobile">Mobile <span class="line"></span></div>
    <div class="stack-grid">
      <div class="chip"><div class="chip-name">Flutter</div><div class="chip-sub">Cross-platform</div></div>
      <div class="chip"><div class="chip-name">React Native</div><div class="chip-sub">Cross-platform</div></div>
    </div>
  </div>
  <div class="backend">
    <div class="stack-section-title backend">Backend <span class="line"></span></div>
    <div class="stack-grid">
      <div class="chip"><div class="chip-name">Node.js</div><div class="chip-sub">Runtime</div></div>
      <div class="chip"><div class="chip-name">Spring</div><div class="chip-sub">Java Framework</div></div>
      <div class="chip"><div class="chip-name">Prisma</div><div class="chip-sub">ORM</div></div>
    </div>
  </div>
  <div class="database">
    <div class="stack-section-title database">Banco de Dados <span class="line"></span></div>
    <div class="stack-grid">
      <div class="chip"><div class="chip-name">PostgreSQL</div><div class="chip-sub">Relacional</div></div>
      <div class="chip"><div class="chip-name">MongoDB</div><div class="chip-sub">NoSQL</div></div>
    </div>
  </div>
  <div class="cloud">
    <div class="stack-section-title cloud">Cloud & Infra <span class="line"></span></div>
    <div class="stack-grid">
      <div class="chip"><div class="chip-name">AWS</div><div class="chip-sub">EC2 · SNS · IAM</div></div>
      <div class="chip"><div class="chip-name">Linux</div><div class="chip-sub">Servers · Nginx</div></div>
    </div>
  </div>
  <div class="security">
    <div class="stack-section-title security">Segurança <span class="line"></span></div>
    <div class="stack-grid">
      <div class="chip"><div class="chip-name">Kali Linux</div><div class="chip-sub">Pentest</div></div>
      <div class="chip"><div class="chip-name">SQL Injection</div><div class="chip-sub">Offensive</div></div>
      <div class="chip"><div class="chip-name">Brute Force</div><div class="chip-sub">Attack Vector</div></div>
    </div>
  </div>
</div>

<!-- ===== PROJECTS ===== -->
<div class="panel p-center p-projects" id="panel-projects">
  <button class="close-btn" onclick="go('hero')">×</button>
  <div class="tag">projetos</div>
  <div class="title">Construções<br><span class="gradient">digitais</span></div>
